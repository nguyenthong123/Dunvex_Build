rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthed() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasAccess(docOwnerId) {
      return isAuthed() && (
        request.auth.uid == docOwnerId || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().ownerId == docOwnerId)
      );
    }

    function hasAccessToResource() {
      let existingOwnerId = resource != null && 'ownerId' in resource.data ? resource.data.ownerId : 'UNKNOWN';
      let newOwnerId = request.resource != null && 'ownerId' in request.resource.data ? request.resource.data.ownerId : 'UNKNOWN';
      return request.resource == null ? hasAccess(existingOwnerId) : (resource == null ? hasAccess(newOwnerId) : (hasAccess(existingOwnerId) && hasAccess(newOwnerId)));
    }

    match /users/{userId} {
      allow read, write: if isAuthed() && (
        request.auth.uid == userId || 
        (resource != null && resource.data.ownerId == request.auth.uid) ||
        (request.resource != null && request.resource.data.ownerId == request.auth.uid)
      );
    }
    
    match /permissions/{docId} {
      allow read, write: if isAuthed();
    }

    match /payment_requests/{docId} {
      allow read, write: if isAuthed();
    }
    
    match /system_config/{docId} {
      allow read: if isAuthed();
    }

    match /coupons/{docId} {
      allow read, write: if isAuthed();
    }
    
    match /settings/{docId} {
      allow read, write: if isAuthed() && (request.auth.uid == docId || hasAccess(docId));
    }

    match /usage_limits/{docId} {
      allow read, write: if isAuthed();
    }

    // Business Collections
    match /products/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
    match /customers/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
    match /orders/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
    match /inventory_logs/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
    match /audit_logs/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
    match /payments/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
    match /debts/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
    match /finance_transactions/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
    match /checkins/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
    
    // Additional Missing Collections
    match /price_lists/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
    match /attendance_logs/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
    match /notifications/{docId} { 
      allow read, write: if isAuthed() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (request.resource != null && request.resource.data.userId == request.auth.uid)
      ); 
    }
    match /ai_actions/{docId} { allow read, write: if isAuthed() && hasAccessToResource(); }
  }
}
