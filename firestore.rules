rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthed() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthed() && request.auth.token.email == 'dunvex.green@gmail.com';
    }

    // Global Admin Bypass
    match /{document=**} {
      allow read, write: if isAdmin();
    }
    
    function getUserData() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null ? userDoc.data : null;
    }

    function userOwnerId() {
      return ('ownerId' in request.auth.token && request.auth.token.ownerId != null)
             ? request.auth.token.ownerId
             : (getUserData() != null ? getUserData().ownerId : null);
    }

    // Business Collections — dùng helpers an toàn với null user doc
    function allowByOwner() {
      return isAuthed() && (
        resource == null || 
        resource.data.ownerId == request.auth.uid || 
        userOwnerId() == resource.data.ownerId
      );
    }
    function allowCreateByOwner() {
      return isAuthed() && (
        request.resource.data.ownerId == request.auth.uid || 
        userOwnerId() == request.resource.data.ownerId
      );
    }

    match /users/{userId} {
      allow read, write: if isAuthed() && (
        request.auth.uid == userId || 
        (resource != null && resource.data.ownerId == request.auth.uid) ||
        (request.resource != null && request.resource.data.ownerId == request.auth.uid)
      );
    }
    
    match /permissions/{docId} {
      allow read: if isAuthed();
      allow create: if isAdmin() || allowCreateByOwner();
      allow update, delete: if isAdmin() || allowByOwner();
    }

    match /system_config/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    match /subscription_packages/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read, write: if isAuthed() && (request.auth.uid == docId || (userOwnerId() != null && userOwnerId() == docId));
    }

    // Business Collections — dùng helpers an toàn với null user doc
    match /products/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /customers/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /orders/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /inventory_logs/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /audit_logs/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /payments/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /debts/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /suppliers/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /purchase_orders/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /supplier_debts/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /finance_transactions/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /checkins/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /price_lists/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /attendance_logs/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /field_config/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /coupons/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /rebate_tiers/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /usage_limits/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /payment_requests/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    
    // API Keys
    match /api_keys/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /bot_chats/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }
    match /ai_actions/{docId} {
      allow read, update, delete: if allowByOwner();
      allow create: if allowCreateByOwner();
    }

    // 👤 Hồ sơ cá nhân
    match /profiles/{userId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }

    // 🔔 Notifications
    match /notifications/{docId} {
      allow read: if isAuthed() && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        (userOwnerId() != null && userOwnerId() == resource.data.userId)
      );
      allow create: if isAuthed() && (
        request.resource.data.userId == request.auth.uid ||
        (userOwnerId() != null && userOwnerId() == request.resource.data.userId)
      );
      allow update, delete: if isAuthed() && resource != null && (
        resource.data.userId == request.auth.uid ||
        (userOwnerId() != null && userOwnerId() == resource.data.userId)
      );
    }
  }
}