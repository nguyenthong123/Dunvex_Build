rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Auth helpers ──
    function isAuthed() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthed() && request.auth.token.email == 'dunvex.green@gmail.com';
    }

    // Global Admin Bypass
    match /{document=**} {
      allow read, write: if isAdmin();
    }
    
    // 🔧 An toàn: trả về '' thay vì null → không crash .ownerId
    // ⚠️ CHỈ gọi trong || chain (lazy eval) — không extract ra biến trước!
    function getOrgOwnerId() {
      let data = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return data != null && data.ownerId != null ? data.ownerId : '';
    }

    // ── Business doc access (dùng chung) ──
    // ⚠️ QUAN TRỌNG: getOrgOwnerId() phải nằm SAU || để lazy eval
    // Nếu extract ra biến → gọi get() luôn → crash khi users doc null
    function canReadDoc(doc) {
      return isAuthed() && (
        doc == null ||
        doc.data.ownerId == request.auth.uid ||
        getOrgOwnerId() == doc.data.ownerId
      );
    }
    
    function canWriteDoc(existing, incoming) {
      return isAuthed() && (
        (existing == null || existing.data.ownerId == request.auth.uid || getOrgOwnerId() == existing.data.ownerId) &&
        (incoming == null || incoming.data.ownerId == request.auth.uid || getOrgOwnerId() == incoming.data.ownerId)
      );
    }

    // ── Special collections ──
    match /users/{userId} {
      allow read, write: if isAuthed() && (
        request.auth.uid == userId || 
        (resource != null && resource.data.ownerId == request.auth.uid) ||
        (request.resource != null && request.resource.data.ownerId == request.auth.uid)
      );
    }
    
    match /system_config/{docId} {
      allow read, write: if isAdmin();
    }

    match /subscription_packages/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    match /permissions/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read, write: if isAuthed() && (
        request.auth.uid == docId || 
        canWriteDoc(resource, request.resource)
      );
    }

    match /profiles/{userId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }

    // ── Notifications ──
    match /notifications/{docId} {
      allow read: if isAuthed() && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        getOrgOwnerId() == resource.data.userId
      );
      allow create: if isAuthed() && (
        request.resource.data.userId == request.auth.uid ||
        getOrgOwnerId() == request.resource.data.userId
      );
      allow update, delete: if isAuthed() && resource != null && (
        resource.data.userId == request.auth.uid ||
        getOrgOwnerId() == resource.data.userId
      );
    }

    // Payment requests
    match /payment_requests/{docId} {
      allow read, create, update, delete: if canWriteDoc(resource, request.resource);
    }

    // ── Business Collections ──
    match /products/{docId}           { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /customers/{docId}          { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /orders/{docId}             { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /inventory_logs/{docId}     { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /audit_logs/{docId}         { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /payments/{docId}           { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /debts/{docId}              { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /finance_transactions/{docId} { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /checkins/{docId}           { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /bot_chats/{docId}          { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /price_lists/{docId}        { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /attendance_logs/{docId}    { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /coupons/{docId}            { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /usage_limits/{docId}       { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
    match /ai_actions/{docId}         { allow read, create, update, delete: if canWriteDoc(resource, request.resource); }
  }
}