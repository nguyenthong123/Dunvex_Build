rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ── Auth helpers ──
    function isAuthed() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthed() && request.auth.token.email == 'dunvex.green@gmail.com';
    }

    // Global Admin Bypass
    match /{document=**} {
      allow read, write: if isAdmin();
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // ── Business doc access (dùng chung cho mọi collection) ──
    function canWrite(existingDoc, incomingDoc) {
      return isAuthed() && (
        (existingDoc == null || existingDoc.data.ownerId == request.auth.uid || getUserData().ownerId == existingDoc.data.ownerId) &&
        (incomingDoc == null || incomingDoc.data.ownerId == request.auth.uid || getUserData().ownerId == incomingDoc.data.ownerId)
      );
    }

    // ── Special collections ──
    match /users/{userId} {
      allow read, write: if isAuthed() && (
        request.auth.uid == userId || 
        (resource != null && resource.data.ownerId == request.auth.uid) ||
        (request.resource != null && request.resource.data.ownerId == request.auth.uid)
      );
    }
    
    // Chỉ admin đọc/ghi system config
    match /system_config/{docId} {
      allow read, write: if isAdmin();
    }

    // Chỉ admin ghi, mọi người đọc subscription packages
    match /subscription_packages/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // Mọi người đọc, admin ghi permissions
    match /permissions/{docId} {
      allow read: if isAuthed();
      allow write: if isAdmin();
    }

    // Settings: chủ settings hoặc trùng ownerId
    match /settings/{docId} {
      allow read, write: if isAuthed() && (
        request.auth.uid == docId || 
        canWrite(resource, request.resource)
      );
    }

    // 👤 Profile: mỗi user chỉ đọc/ghi của chính mình
    match /profiles/{userId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }

    // ── Notifications: fix bug resource == null ──
    match /notifications/{docId} {
      allow read: if isAuthed() && (
        resource == null ||
        resource.data.userId == request.auth.uid ||
        getUserData().ownerId == resource.data.userId
      );
      allow create: if isAuthed() && (
        request.resource.data.userId == request.auth.uid ||
        getUserData().ownerId == request.resource.data.userId
      );
      allow update, delete: if isAuthed() && resource != null && (
        resource.data.userId == request.auth.uid ||
        getUserData().ownerId == resource.data.userId
      );
    }

    // Payment requests
    match /payment_requests/{docId} {
      allow read, create, update, delete: if canWrite(resource, request.resource);
    }

    // ── Business Collections (dùng chung pattern) ──
    match /products/{docId}           { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /customers/{docId}          { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /orders/{docId}             { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /inventory_logs/{docId}     { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /audit_logs/{docId}         { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /payments/{docId}           { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /debts/{docId}              { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /finance_transactions/{docId} { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /checkins/{docId}           { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /bot_chats/{docId}          { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /price_lists/{docId}        { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /attendance_logs/{docId}    { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /coupons/{docId}            { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /usage_limits/{docId}       { allow read, create, update, delete: if canWrite(resource, request.resource); }
    match /ai_actions/{docId}         { allow read, create, update, delete: if canWrite(resource, request.resource); }
  }
}