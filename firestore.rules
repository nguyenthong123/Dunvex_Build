rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthed() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasAccess(docOwnerId) {
      return isAuthed() && (
        request.auth.uid == docOwnerId || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().ownerId == docOwnerId)
      );
    }



    match /users/{userId} {
      allow read, write: if isAuthed() && (
        request.auth.uid == userId || 
        (resource != null && resource.data.ownerId == request.auth.uid) ||
        (request.resource != null && request.resource.data.ownerId == request.auth.uid)
      );
    }
    
    match /permissions/{docId} {
      allow read, write: if isAuthed();
    }

    match /payment_requests/{docId} {
      allow read, write: if isAuthed();
    }
    
    match /system_config/{docId} {
      allow read: if isAuthed();
    }

    match /coupons/{docId} {
      allow read, write: if isAuthed();
    }
    
    match /settings/{docId} {
      allow read, write: if isAuthed() && (request.auth.uid == docId || hasAccess(docId));
    }

    match /usage_limits/{docId} {
      allow read, write: if isAuthed();
    }

    function canWriteResource() {
      let isUpdate = resource != null;
      let existingValid = !isUpdate || hasAccess(resource.data.ownerId);
      let newValid = request.resource == null || hasAccess(request.resource.data.ownerId);
      return existingValid && newValid;
    }

    // Business Collections
    match /products/{docId} { allow read, write: if isAuthed() && (resource.data.ownerId == request.auth.uid || getUserData().ownerId == resource.data.ownerId); }
    match /customers/{docId} { allow read, write: if isAuthed() && (resource.data.ownerId == request.auth.uid || getUserData().ownerId == resource.data.ownerId); }
    match /orders/{docId} { allow read, write: if isAuthed() && (resource.data.ownerId == request.auth.uid || getUserData().ownerId == resource.data.ownerId); }
    match /inventory_logs/{docId} { allow read, write: if isAuthed() && (resource.data.ownerId == request.auth.uid || getUserData().ownerId == resource.data.ownerId); }
    match /audit_logs/{docId} { allow read, write: if isAuthed() && (resource.data.ownerId == request.auth.uid || getUserData().ownerId == resource.data.ownerId); }
    match /payments/{docId} { allow read, write: if isAuthed() && (resource.data.ownerId == request.auth.uid || getUserData().ownerId == resource.data.ownerId); }
    match /debts/{docId} { allow read, write: if isAuthed() && (resource.data.ownerId == request.auth.uid || getUserData().ownerId == resource.data.ownerId); }
    match /finance_transactions/{docId} { allow read, write: if isAuthed() && (resource.data.ownerId == request.auth.uid || getUserData().ownerId == resource.data.ownerId); }
    match /checkins/{docId} { allow read, write: if isAuthed() && (resource.data.ownerId == request.auth.uid || getUserData().ownerId == resource.data.ownerId); }
    
    // Additional Missing Collections
    match /price_lists/{docId} { allow read, write: if isAuthed() && (resource.data.ownerId == request.auth.uid || getUserData().ownerId == resource.data.ownerId); }
    match /attendance_logs/{docId} { allow read, write: if isAuthed() && (resource.data.ownerId == request.auth.uid || getUserData().ownerId == resource.data.ownerId); }
    match /notifications/{docId} { 
      allow read, write: if isAuthed() && (
        (resource != null && resource.data.userId == request.auth.uid) ||
        (request.resource != null && request.resource.data.userId == request.auth.uid)
      ); 
    }
    match /ai_actions/{docId} { allow read: if isAuthed() && canReadResource(); allow write: if isAuthed() && canWriteResource(); }
  }
}
